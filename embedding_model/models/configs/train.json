{
  "data": {
    "rated_path": "data/fineweb_edu_88k_rated.jsonl",
    "hand_annotations_path": "data/hand_annotated_samples.jsonl",
    "rating_config_path": "config.json",
    "validation_fraction": 0.05,
    "prefix_match_chars": 200
  },
  "model": {
    "base_model_path": "embedding_model/models/base_model",
    "max_length": 8192,
    "attention_implementation": "sdpa",
    "gradient_checkpointing": true
  },
  "lora": {
    "rank": 8,
    "alpha": 16,
    "dropout": 0.0,
    "target_modules": [
      "tok_embeddings",
      "Wqkv",
      "Wi",
      "Wo"
    ]
  },
  "optimization": {
    "epochs": 3,
    "batch_size": 2,
    "learning_rate": 0.0001,
    "betas": [0.9, 0.999],
    "weight_decay": 0.01,
    "max_grad_norm": 1.0,
    "warmup_fraction": 0.1,
    "cosine_decay_fraction": 0.3
  },
  "logging": {
    "log_every": 10,
    "val_every": 100,
    "checkpoint_dir": "embedding_model/checkpoints"
  },
  "runtime": {
    "seed": 42,
    "device": "cuda",
    "precision": "auto",
    "num_workers": 0
  }
}
