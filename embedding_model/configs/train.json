{
  "data": {
    "rated_path": "embedding_model/data/fineweb_edu_88k_rated.jsonl",
    "hand_annotations_path": "embedding_model/data/hand_annotated_samples.jsonl",
    "rating_config_path": "config.json",
    "validation_fraction": 0.12,
    "prefix_match_chars": 200,
    "upsample_mult": {
      "pom": 8,
      "reification": 2,
      "experience": 1
    }
  },
  "model": {
    "base_model_path": "embedding_model/models/base_model",
    "max_length": 8192,
    "attention_implementation": "sdpa",
    "gradient_checkpointing": false
  },
  "lora": {
    "rank": 16,
    "alpha": 16,
    "dropout": 0.3,
    "use_rslora": true,
    "target_modules": [
      "tok_embeddings",
      "Wqkv",
      "Wi",
      "Wo"
    ]
  },
  "optimization": {
    "epochs": 4,
    "batch_size": 32,
    "learning_rate": 5e-4,
    "betas": [0.98, 0.99],
    "weight_decay": 20.0,
    "max_grad_norm": 1.0,
    "warmup_fraction": 0.1,
    "cosine_decay_fraction": 0.3
  },
  "logging": {
    "log_every": 1,
    "val_every": 20,
    "checkpoint_dir": "embedding_model/checkpoints"
  },
  "runtime": {
    "seed": 42,
    "device": "cuda",
    "precision": "auto",
    "num_workers": 0
  }
}
