{
  "data": {
    "rated_path": "embedding_model/data/fineweb_edu_88k_rated.jsonl",
    "hand_annotations_path": "llm_judge/data/hand_annotated_samples.jsonl",
    "hand_rated_path": "llm_judge/data/hand_annotated_rated.jsonl",
    "rating_config_path": "llm_judge/config.json",
    "validation_fraction": 0.1,
    "prefix_match_chars": 200,
    "upsample_mult": {
      "pom": 8,
      "reification": 2,
      "experience": 1
    }
  },
  "model": {
    "base_model_path": "embedding_model/models/base_model",
    "max_length": 8192,
    "attention_implementation": "sdpa",
    "gradient_checkpointing": false
  },
  "lora": {
    "rank": 32,
    "alpha": 16,
    "dropout": 0.25,
    "use_rslora": true,
    "target_modules": [
      "tok_embeddings",
      "Wqkv",
      "Wi",
      "Wo"
    ]
  },
  "optimization": {
    "batch_size": 16,

    "learning_rate": 3e-4,
    "weight_decay": 15.0,
    "epochs": 4,

    "betas": [0.9, 0.99],
    "max_grad_norm": 1.0,
    "warmup_fraction": 0.1,
    "cosine_decay_fraction": 0.3

  },
  "logging": {
    "log_every": 5,
    "val_every": 25,
    "checkpoint_dir": "embedding_model/checkpoints"
  },
  "runtime": {
    "seed": 42,
    "device": "cuda",
    "precision": "auto",
    "num_workers": 0
  }
}
