{
  "download_settings" : {
    "dataset": {
      "repo_id": "HuggingFaceFW/fineweb-edu",
      "revision": "main",
      "sample_prefix": "sample/10BT"
    },
    "output_jsonl": "full_pretrain_filter/data/fineweb_edu.jsonl",
