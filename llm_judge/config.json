{
  "input_jsonl": "llm_judge/data/fineweb_edu_88k.jsonl",
  "output_jsonl": "llm_judge/data/fineweb_edu_88k_rated.jsonl",
  "hand_annotations_jsonl": "llm_judge/data/hand_annotated_samples.jsonl",
  "filters": [
    {
      "name": "philosophy_of_mind",
      "prompt_path": "llm_judge/prompts/PhilosophyOfMindClassifier.txt"
    },
    {
      "name": "reified_experience",
      "prompt_path": "llm_judge/prompts/ReifiedExperienceClassifier.txt"
    },
    {
      "name": "experience_descriptions",
      "prompt_path": "llm_judge/prompts/ExperienceDescriptionsClassifier.txt"
    }
  ],
  "grading_instruction_path": "llm_judge/prompts/grading_instruction.txt",
  "models": [
    "google/gemma-4-31b-it",
    "x-ai/grok-4.5",
    "openai/gpt-5.6-luna"
  ],
  "openrouter": {
    "api_key_env": "OPENROUTER_API_KEY",
    "chat_url": "https://openrouter.ai/api/v1/chat/completions",
    "app_title": "consciousness_filter",
    "http_referer": null
  },
  "request": {
    "reasoning_effort": "medium",
    "max_output_tokens": 8000,
    "max_retries": 3,
    "retry_base_delay_seconds": 5.0,
    "timeout_seconds": 60.0
  },
  "run": {
    "batch_size": 64,
    "max_concurrent_requests": 128,
    "max_documents": 12000
  }
}
